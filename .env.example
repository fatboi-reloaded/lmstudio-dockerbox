# =============================================================
# .env.example — copy to .env and fill in the values below
# .env is gitignored; never commit your real secrets.
# =============================================================

# ------ Tailscale --------------------------------------------
# Auth key from https://login.tailscale.com/admin/settings/keys
# Reusable ephemeral keys work well for containers:
#   tailscale.com/kb/1085/auth-keys
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Hostname that will appear in your Tailscale admin console
TS_HOSTNAME=lmstudio

# Extra Tailscale flags (optional)
# Example to advertise tags: --advertise-tags=tag:servers
TS_EXTRA_ARGS=--accept-routes

# ------ VNC / noVNC ------------------------------------------
# Browser access: http://<TS_HOSTNAME>:6080/vnc.html
# Password must be 6–8 characters (VNC protocol limit)
VNC_PASSWORD=changeme

# Desktop resolution (width x height)
VNC_RESOLUTION=1920x1080

# noVNC HTTP port (only reachable inside the Tailnet)
NOVNC_PORT=6080

# ------ LM Studio build --------------------------------------
# LM Studio version label (informational — the URL below drives what is actually installed).
# Set to a semver string like 0.3.9 only if you also override LMS_DEB_URL below.
LMS_VERSION=latest

# Download URL — defaults to the official stable redirect.
# Override with a versioned URL to pin a specific release, e.g.:
# LMS_DEB_URL=https://releases.lmstudio.ai/linux/deb/x86_64/0.3.9/lmstudio-0.3.9-x86_64.deb
# LMS_DEB_URL=https://lmstudio.ai/download/latest/linux/x64?format=deb

# ------ NVIDIA CUDA base image version -----------------------
# See available tags: https://hub.docker.com/r/nvidia/cuda/tags
CUDA_VERSION=12.3.1
