#!/usr/bin/env bash

set -euo pipefail

find_lmstudio_bin() {
    local candidate
    for candidate in \
        "/opt/LM Studio/lm-studio" \
        "/opt/LM Studio/lmstudio" \
        "/opt/lmstudio/lm-studio" \
        "/opt/lmstudio/lmstudio" \
        "/usr/bin/lmstudio" \
        "/usr/local/bin/lmstudio-bin"
    do
        if [[ -x "${candidate}" ]]; then
            printf '%s\n' "${candidate}"
            return 0
        fi
    done

    candidate="$(find /opt /usr -maxdepth 4 -type f \( -name 'lm-studio' -o -name 'lmstudio' \) 2>/dev/null | head -n 1 || true)"
    [[ -n "${candidate}" ]] || return 1
    printf '%s\n' "${candidate}"
}

LMSTUDIO_BIN="$(find_lmstudio_bin || true)"
if [[ -z "${LMSTUDIO_BIN}" ]]; then
    echo "[lmstudio-launcher] ERROR: could not locate the LM Studio executable." >&2
    exit 1
fi

export ELECTRON_DISABLE_SANDBOX=1

exec "${LMSTUDIO_BIN}" --no-sandbox --disable-setuid-sandbox "$@"
